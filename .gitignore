# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/

# Environment variables
.env
.env.local
.env.production

# API Key（含真实 key，勿提交）
EM_API_KEY.local

# Runtime outputs (Python 脚本的临时输出目录，读取后立即清理)
tmp/*
!tmp/.gitkeep
# 兼容旧版 Python 脚本可能写入的目录，防止意外提交
history/
miaoxiang/

# Python virtual environments and caches
.venv/
venv/
**/venv/
python/venv/
__pycache__/
*.pyc
.pytest_cache/

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Editor directories
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
